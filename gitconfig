[user]
	name = Jianjian Huang
	email = jianjian.huang@utah.edu

[init]
	defaultBranch = main

[core]
	editor = vim
	autocrlf = input
	pager = "delta 2>/dev/null || less 2>/dev/null || cat"

[interactive]
	diffFilter = "delta --color-only 2>/dev/null || cat"

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[pull]
	rebase = true

[push]
	default = current
	autoSetupRemote = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[fetch]
	prune = true
	pruneTags = true

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default
	renames = true

[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true

[commit]
	verbose = true

[help]
	autocorrect = prompt

[rerere]
	enabled = true

[include]
	path = ~/.server-configs-generated/gitconfig.compat

[alias]
	s = status
	co = checkout
	br = branch
	ci = commit
	d = diff
	ds = diff --staged
	lg = log --oneline --graph --decorate -20
	la = log --oneline --graph --decorate --all -30
	undo = reset --soft HEAD~1
	amend = commit --amend --no-edit
	stash-all = stash save --include-untracked
	wip = !git add -A && git commit -m 'WIP'

[color]
	ui = auto
