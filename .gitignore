# Backups created by install.sh (backup_and_link / backup_and_copy)
*.bak

# Local overrides / generated state
.dotfiles-generated/
*.local

# Auth / secret material — never commit
.credentials.json
auth.json
hosts.yml
*.pem
*.key
*.keystore
.env
.env.*

# Editor / OS
.DS_Store
*.swp
*.swo
.vim/undodir/

# Python build/cache artifacts
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Per-host lazy.nvim plugin lockfile. We don't pin plugin versions across
# hosts (this is a personal dotfiles repo, not a reproducible-build one);
# `:Lazy sync` rewriting the lock on each machine would otherwise leave
# the working tree dirty.
editor/nvim/lazy-lock.json
