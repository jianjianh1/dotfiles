# VS Code remote helpers (installed by setup.sh).
# vscode-tunnel: start a `code tunnel` on this host. First run prompts for
# GitHub/MS login; subsequent runs reuse the cached auth and print a
# vscode.dev URL (also reachable via the Remote-Tunnels extension in a local
# VS Code). Default tunnel name = short hostname.
#   Usage: vscode-tunnel [<name>] [<dir>]
# If <dir> is given, prints a vscode.dev URL that opens straight to that folder.
vscode-tunnel() {
    command -v code >/dev/null 2>&1 || { echo "code CLI not installed (run setup.sh)"; return 1; }
    local name="${1:-$(hostname -s)}"
    local dir="${2:-}"
    if [ -n "$dir" ]; then
        dir=$(cd "$dir" 2>/dev/null && pwd) || { echo "vscode-tunnel: directory not found: $2"; return 1; }
        echo "Open in browser: https://vscode.dev/tunnel/$name$dir"
    fi
    code tunnel --name "$name" --accept-server-license-terms
}

# vscode-tunnel-compute: start a `code tunnel` on a SLURM compute node as a
# detached sbatch job. Returns immediately; the tunnel survives the launching
# terminal closing and is reachable via https://vscode.dev/tunnel/<name>.
# Use this on CHPC login nodes — Arbiter caps login-node processes at 4
# cores / 8 GB, which is not enough for cpptools IntelliSense to finish
# scanning. Defaults to notchpeak-shared-short (no allocation required); set
# VSCODE_TUNNEL_{ACCOUNT,PARTITION,QOS,CORES,MEM,TIME} to override.
#
# Idempotent: re-running while a tunnel with the same name is RUNNING
# reuses it and reprints the URL — no second sbatch.
#
# Auth note: `code tunnel user show` on a login node passes because the
# token decrypts via the gnome-keyring running there. Compute nodes have no
# keyring daemon, so the *first* run on a compute node triggers a one-time
# device-code login (https://github.com/login/device + an 8-char code) — we
# tail the slurm log briefly and print the prompt or success URL. After that
# the token is re-stored in a keyringless mode that works on compute nodes.
#
#   Usage: vscode-tunnel-compute [<name>] [<dir>]
# Tunnel name defaults to notch-dev. If <dir> is given, prints a vscode.dev URL
# that opens straight to that folder.
vscode-tunnel-compute() {
    command -v sbatch >/dev/null 2>&1 || { echo "sbatch not found — not a SLURM host"; return 1; }
    command -v code   >/dev/null 2>&1 || { echo "code CLI not installed (run setup.sh)"; return 1; }

    local name="${1:-notch-dev}"
    local dir="${2:-}"
    local url="https://vscode.dev/tunnel/$name"
    if [ -n "$dir" ]; then
        dir=$(cd "$dir" 2>/dev/null && pwd) || { echo "vscode-tunnel-compute: directory not found: $2"; return 1; }
        url="$url$dir"
    fi

    local jobname="vscode-tunnel-$name"
    local existing
    existing="$(squeue -h -u "$USER" -n "$jobname" -t RUNNING -o '%i %N' 2>/dev/null | head -n1)"
    if [ -n "$existing" ]; then
        echo "Tunnel '$name' already running (job ${existing%% *} on ${existing##* })."
        echo "Open in browser: $url"
        echo "Log:  ~/.local/share/vscode-tunnel-$name.log"
        echo "Stop: vscode-tunnel-release $name"
        return 0
    fi

    local acct="${VSCODE_TUNNEL_ACCOUNT:-notchpeak-shared-short}"
    local part="${VSCODE_TUNNEL_PARTITION:-notchpeak-shared-short}"
    local qos="${VSCODE_TUNNEL_QOS:-notchpeak-shared-short}"
    local cores="${VSCODE_TUNNEL_CORES:-8}"
    local mem="${VSCODE_TUNNEL_MEM:-32G}"
    local time="${VSCODE_TUNNEL_TIME:-8:00:00}"
    local logfile="$HOME/.local/share/vscode-tunnel-$name.log"
    mkdir -p "$(dirname "$logfile")" 2>/dev/null || true

    # Clear the previous log so device-code / URL grepping picks up only this
    # run. Keeping it short (truncate, don't unlink) preserves an open `tail
    # -f` from a parallel terminal.
    : > "$logfile" 2>/dev/null || true

    local jobid
    jobid="$(sbatch --parsable -A "$acct" -p "$part" -q "$qos" \
                    -n "$cores" --mem="$mem" -t "$time" -J "$jobname" \
                    -o "$logfile" -e "$logfile" \
                    --wrap="exec code tunnel --accept-server-license-terms --name '$name'")" \
        || { echo "sbatch failed"; return 1; }
    [ -n "$jobid" ] && [ "$jobid" != "0" ] || { echo "submission failed"; return 1; }

    echo "Submitted tunnel job $jobid ('$jobname'). Waiting for node..."
    local node="" tries=0
    while [ "$tries" -lt 120 ]; do
        node="$(squeue -h -j "$jobid" -o '%N' 2>/dev/null)"
        case "$node" in
            ""|"(null)"|n/a) ;;
            *) break ;;
        esac
        sleep 2
        tries=$((tries + 1))
    done
    if [ -z "$node" ] || [ "$node" = "(null)" ]; then
        echo "Timed out waiting for allocation. scancel $jobid to drop."
        return 1
    fi
    echo "Tunnel running on $node."

    # Watch the log for the tunnel's first interesting line (up to ~30 s):
    # either a device-code prompt (one-time first-run from compute) or the
    # vscode.dev URL banner (success). Read incrementally with `tail -F` so
    # we don't busy-poll.
    local saw_device=0 saw_url=0 line waited=0
    while IFS= read -r line; do
        case "$line" in
            *"https://github.com/login/device"*)
                saw_device=1
                break
                ;;
            *"Open this link in your browser"*)
                saw_url=1
                break
                ;;
        esac
        waited=$((waited + 1))
        [ "$waited" -gt 60 ] && break
    done < <(timeout 30 tail -F -n +1 "$logfile" 2>/dev/null)

    if [ "$saw_device" = 1 ]; then
        printf '\n\033[33mFirst-run device-code login required on the compute node.\033[0m\n'
        printf 'Compute nodes have no keyring; the token from the login node\n'
        printf "can't be decrypted there. Complete the device-code prompt once:\n\n"
        grep -E "https://github.com/login/device|use code [A-Z0-9-]+" "$logfile" 2>/dev/null \
            | tail -n 3 | sed 's/^/  /'
        printf '\nAfter login, the URL banner appears in the log within seconds:\n'
        printf '  tail -F %s\n' "$logfile"
        printf '\nOpen in browser (after auth): %s\n' "$url"
        printf 'Stop: vscode-tunnel-release %s   (or scancel %s)\n' "$name" "$jobid"
        return 0
    fi

    if [ "$saw_url" = 1 ]; then
        echo "Open in browser: $url"
        echo "Log:  tail -f $logfile"
        echo "Stop: vscode-tunnel-release $name   (or scancel $jobid)"
        return 0
    fi

    # No banner seen — slow boot or something else. Hand off cleanly.
    echo "Tunnel daemon not ready yet (no URL banner in 30 s)."
    echo "Watch:  tail -F $logfile"
    echo "Once ready, open: $url"
    echo "Stop: vscode-tunnel-release $name   (or scancel $jobid)"
}

# vscode-tunnel-release: scancel the sbatch job behind vscode-tunnel-compute.
# Pass a tunnel name to target a specific tunnel (default: notch-dev). Each
# tunnel is its own job named 'vscode-tunnel-<name>' — we never wildcard
# across all of them, to avoid surprises when you have more than one.
vscode-tunnel-release() {
    command -v scancel >/dev/null 2>&1 || { echo "scancel not found"; return 1; }
    local name="${1:-notch-dev}"
    local jobname="vscode-tunnel-$name"
    local ids
    ids=$(squeue -h -u "$USER" -n "$jobname" -o '%i' 2>/dev/null)
    if [ -z "$ids" ]; then
        echo "no tunnel '$name' running"
        return 0
    fi
    echo "cancelling: $ids"
    # shellcheck disable=SC2086
    scancel $ids
}

# Manual theme override. `theme auto` re-runs detect-theme (clears the cached
# SERVER_CONFIGS_THEME first, otherwise the early-return in
# _server_configs_detect_theme would no-op). Inside tmux, propagate to the
# global env so new panes inherit and re-source the theme block to repaint
# existing panes. Running nvim/vim instances cache &background at startup and
# need `:set background=light|dark` to flip via the OptionSet autocmd.
theme() {
    case "${1:-auto}" in
        light|dark)
            export SERVER_CONFIGS_THEME="$1"
            ;;
        auto)
            # Inside tmux, auto-detect needs an in-session probe — tmux 3.6+
            # exposes #{client_theme}; older tmux has neither that nor
            # allow-passthrough'd OSC 11. Without a probe, detect-theme falls
            # through to its dark default and would overwrite a possibly-correct
            # cached value, so refuse on legacy tmux and tell the user.
            if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
                case "$(tmux display -p '#{client_theme}' 2>/dev/null)" in
                    light|dark) ;;
                    *)
                        printf 'theme: auto-detect inside tmux %s is not supported (need tmux 3.6+ #{client_theme}). Open a fresh outside-tmux terminal, or use `theme light|dark`.\n' \
                            "$(tmux -V 2>/dev/null | awk '{print $2}')" >&2
                        return 1
                        ;;
                esac
            fi
            unset SERVER_CONFIGS_THEME
            # Bust tmux's global-env cache so detect-theme step 2a falls
            # through to a real #{client_theme} re-probe instead of
            # returning the value cached by an earlier run.
            if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
                tmux set-environment -g -u SERVER_CONFIGS_THEME 2>/dev/null || true
            fi
            if command -v _server_configs_detect_theme >/dev/null 2>&1; then
                _server_configs_detect_theme force
            fi
            ;;
        -h|--help|help)
            printf 'usage: theme [light|dark|auto]\n' >&2
            return 0
            ;;
        *)
            printf 'theme: unknown argument %s (expected light|dark|auto)\n' "$1" >&2
            return 2
            ;;
    esac
    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        tmux set-environment -g SERVER_CONFIGS_THEME "${SERVER_CONFIGS_THEME:-dark}"
        [ -f "$HOME/.tmux-theme.conf" ] && tmux source-file "$HOME/.tmux-theme.conf" 2>/dev/null
    fi
    printf 'theme: SERVER_CONFIGS_THEME=%s%s\n' "${SERVER_CONFIGS_THEME:-unset}" \
        "${TMUX:+ (tmux repainted; running nvim/vim: :set background=...)}" >&2
}

