# shellcheck shell=bash
# shellcheck disable=SC2262

DOTFILES_OS="$(uname -s 2>/dev/null || printf unknown)"

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ls (use eza if available)
if command -v eza &>/dev/null; then
    alias ls='eza --group-directories-first'
    alias ll='eza -la --group-directories-first --git'
    alias la='eza -a --group-directories-first'
    alias lt='eza -T --level=2'
elif ls --color=auto -d . >/dev/null 2>&1; then
    alias ls='ls --color=auto'
    alias ll='ls -alFh --color=auto'
    alias la='ls -A --color=auto'
elif [ "$DOTFILES_OS" = "Darwin" ]; then
    alias ls='ls -G'
    alias ll='ls -alFhG'
    alias la='ls -AG'
else
    alias ll='ls -alFh'
    alias la='ls -A'
fi
alias l='ls -CF'

# grep
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Git
alias gs='git status -sb'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gpu='git pull'
alias gl='git log --oneline --graph --decorate -20'
alias gla='git log --oneline --all --graph -20'
alias gd='git diff'
alias gds='git diff --staged'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias lg='lazygit'

# Safety nets. `rm -I` (interactive once for >3 files / recursive) is
# GNU coreutils only — vanilla macOS `rm` lacks it. Probe once at shell
# startup and only alias when supported.
if rm --help 2>&1 | grep -q -- '-I'; then
    alias rm='rm -I'
fi
alias mv='mv -i'
alias cp='cp -i'

# Disk usage
alias df='df -h'
alias du='du -h'
alias dud='du -d 1 -h | sort -hr'

# System / quick look
alias h='history | tail -30'
alias j='jobs -l'
if command -v ss &>/dev/null; then
    alias ports='ss -tulnp'
elif command -v lsof &>/dev/null; then
    alias ports='lsof -nP -iTCP -sTCP:LISTEN'
fi
alias myip='curl -s ifconfig.me'
alias cls='clear'
alias path='echo -e ${PATH//:/\\n}'
alias now='date +"%Y-%m-%d %H:%M:%S"'
if [ "$DOTFILES_OS" != "Darwin" ] && command -v xdg-open &>/dev/null; then
    alias open='xdg-open'
fi

# tmux
alias ta='tmux attach -t'
alias tn='tmux new -s'
alias tl='tmux list-sessions'
alias tk='tmux kill-session -t'

# VS Code remote helpers (installed by install.sh).
# vscode-tunnel: subcommand router around `code tunnel`. First run prompts
# for GitHub/MS login; subsequent runs reuse the cached auth and print a
# vscode.dev URL (also reachable via Remote-Tunnels in a local VS Code).
# Run `vscode-tunnel --help` for the full surface. Definition lives in
# ~/.local/lib/vscode-tunnel.sh (symlinked from this repo by install.sh).
if [ -r "$HOME/.local/lib/vscode-tunnel.sh" ]; then
    # shellcheck source=/dev/null
    . "$HOME/.local/lib/vscode-tunnel.sh"
fi


# Manual theme override. `theme auto` re-runs detect-theme (clears the cached
# DOTFILES_THEME first, otherwise the early-return in
# _dotfiles_detect_theme would no-op). Inside tmux, propagate to the
# global env so new panes inherit and re-source the theme block to repaint
# existing panes. Running nvim/vim instances cache &background at startup and
# need `:set background=light|dark` to flip via the OptionSet autocmd.
theme() {
    case "${1:-auto}" in
        light|dark)
            export DOTFILES_THEME="$1"
            ;;
        auto)
            # Inside tmux, auto-detect needs an in-session probe — tmux 3.6+
            # exposes #{client_theme}; older tmux has neither that nor
            # allow-passthrough'd OSC 11. Without a probe, detect-theme falls
            # through to its dark default and would overwrite a possibly-correct
            # cached value, so refuse on legacy tmux and tell the user.
            if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
                case "$(tmux display -p '#{client_theme}' 2>/dev/null)" in
                    light|dark) ;;
                    *)
                        printf 'theme: auto-detect inside tmux %s is not supported (need tmux 3.6+ #{client_theme}). Open a fresh outside-tmux terminal, or use `theme light|dark`.\n' \
                            "$(tmux -V 2>/dev/null | awk '{print $2}')" >&2
                        return 1
                        ;;
                esac
            fi
            unset DOTFILES_THEME
            # Bust tmux's global-env cache so detect-theme step 2a falls
            # through to a real #{client_theme} re-probe instead of
            # returning the value cached by an earlier run.
            if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
                tmux set-environment -g -u DOTFILES_THEME 2>/dev/null || true
            fi
            if command -v _dotfiles_detect_theme >/dev/null 2>&1; then
                _dotfiles_detect_theme force
            fi
            ;;
        -h|--help|help)
            printf 'usage: theme [light|dark|auto]\n' >&2
            return 0
            ;;
        *)
            printf 'theme: unknown argument %s (expected light|dark|auto)\n' "$1" >&2
            return 2
            ;;
    esac
    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        tmux set-environment -g DOTFILES_THEME "${DOTFILES_THEME:-dark}"
        [ -f "$HOME/.tmux-theme.conf" ] && tmux source-file "$HOME/.tmux-theme.conf" 2>/dev/null
    fi
    printf 'theme: DOTFILES_THEME=%s%s\n' "${DOTFILES_THEME:-unset}" \
        "${TMUX:+ (tmux repainted; running nvim/vim: :set background=...)}" >&2
}

# CHPC interactive compute allocation. Login nodes cap each user at 8GB/4cores
# (one shared cgroup) — exceeding it triggers the kernel OOM-killer, which can
# reap Claude. Run Claude + heavy analysis here, not on the login node.
# Usage: cnode [cores] [mem] [hours]   (defaults: 4 cores, 32G, 8h)
if command -v salloc &>/dev/null; then
    cnode() {
        salloc --partition=notchpeak-shared-short \
               --account=notchpeak-shared-short \
               --qos=notchpeak-shared-short \
               --nodes=1 --ntasks="${1:-4}" --mem="${2:-32G}" \
               --time="${3:-8}:00:00"
    }
fi

# Modern tool replacements (guarded)
# bat as cat is safe — same basic interface. fd/rg are used directly (no alias)
# since aliasing grep/find breaks scripts that rely on GNU flag syntax.
command -v bat &>/dev/null && alias cat='bat --paging=never'
command -v fd &>/dev/null && alias ff='fd'

if [ -f ~/.dotfiles-generated/bashrc_compat ]; then
    # shellcheck source=/dev/null
    source ~/.dotfiles-generated/bashrc_compat
fi

# Neovim (alias vim/vi to nvim when available)
if command -v nvim &>/dev/null; then
    alias vim='nvim'
    alias vi='nvim'
fi

# Tool integrations (cached via _dotfiles_load_cached_init from bashrc_exports)
_dotfiles_load_cached_init zoxide "zoxide init bash"
_dotfiles_load_cached_init fzf "fzf --bash"
if [ -f ~/.fzf.bash ]; then
    # shellcheck source=/dev/null
    source ~/.fzf.bash
fi
