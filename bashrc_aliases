# VS Code remote helpers (installed by setup.sh).
# vscode-tunnel: start a `code tunnel` on this host. First run prompts for
# GitHub/MS login; subsequent runs reuse the cached auth and print a
# vscode.dev URL (also reachable via the Remote-Tunnels extension in a local
# VS Code). Default tunnel name = short hostname.
#   Usage: vscode-tunnel [<name>] [<dir>]
# If <dir> is given, prints a vscode.dev URL that opens straight to that folder.
vscode-tunnel() {
    command -v code >/dev/null 2>&1 || { echo "code CLI not installed (run setup.sh)"; return 1; }
    local name="${1:-$(hostname -s)}"
    local dir="${2:-}"
    if [ -n "$dir" ]; then
        dir=$(cd "$dir" 2>/dev/null && pwd) || { echo "vscode-tunnel: directory not found: $2"; return 1; }
        echo "Open in browser: https://vscode.dev/tunnel/$name$dir"
    fi
    code tunnel --name "$name" --accept-server-license-terms
}

# vscode-tunnel-compute: start a `code tunnel` on a SLURM compute node via
# salloc. Use this on CHPC login nodes — Arbiter caps login-node processes at
# 4 cores / 8 GB, which is not enough for cpptools IntelliSense to finish
# scanning. Defaults to notchpeak-shared-short (no allocation required); set
# VSCODE_TUNNEL_{ACCOUNT,PARTITION,QOS,CORES,MEM,TIME} to override.
#   Usage: vscode-tunnel-compute [<name>] [<dir>]
# Tunnel name defaults to notch-dev. If <dir> is given, prints a vscode.dev URL
# that opens straight to that folder.
vscode-tunnel-compute() {
    command -v salloc >/dev/null 2>&1 || { echo "salloc not found — not a SLURM host"; return 1; }
    command -v code   >/dev/null 2>&1 || { echo "code CLI not installed (run setup.sh)"; return 1; }
    local name="${1:-notch-dev}"
    local dir="${2:-}"
    if [ -n "$dir" ]; then
        dir=$(cd "$dir" 2>/dev/null && pwd) || { echo "vscode-tunnel-compute: directory not found: $2"; return 1; }
        echo "Open in browser: https://vscode.dev/tunnel/$name$dir"
    fi
    local acct="${VSCODE_TUNNEL_ACCOUNT:-notchpeak-shared-short}"
    local part="${VSCODE_TUNNEL_PARTITION:-notchpeak-shared-short}"
    local qos="${VSCODE_TUNNEL_QOS:-notchpeak-shared-short}"
    local cores="${VSCODE_TUNNEL_CORES:-8}"
    local mem="${VSCODE_TUNNEL_MEM:-32G}"
    local time="${VSCODE_TUNNEL_TIME:-8:00:00}"
    salloc -A "$acct" -p "$part" -q "$qos" -n "$cores" --mem="$mem" -t "$time" \
        --job-name="vscode-tunnel" \
        bash -lc "code tunnel --name '$name' --accept-server-license-terms"
}

# vscode-ssh-alloc: reserve a CHPC compute node with a long-lived sbatch
# "sleep infinity" job, then print the node name to point VS Code Remote-SSH
# at. The allocation persists across disconnects until you scancel it (or
# wall-time runs out). Override slots via
# VSCODE_SSH_{ACCOUNT,PARTITION,QOS,CORES,MEM,TIME}. Job name defaults to
# vscode-ssh; pass an explicit name as $1.
vscode-ssh-alloc() {
    command -v sbatch >/dev/null 2>&1 || { echo "sbatch not found — not a SLURM host"; return 1; }
    local name="${1:-vscode-ssh}"
    local acct="${VSCODE_SSH_ACCOUNT:-notchpeak-shared-short}"
    local part="${VSCODE_SSH_PARTITION:-notchpeak-shared-short}"
    local qos="${VSCODE_SSH_QOS:-notchpeak-shared-short}"
    local cores="${VSCODE_SSH_CORES:-8}"
    local mem="${VSCODE_SSH_MEM:-32G}"
    local time="${VSCODE_SSH_TIME:-8:00:00}"
    local jobid
    jobid=$(sbatch --parsable -A "$acct" -p "$part" -q "$qos" \
                   -n "$cores" --mem="$mem" -t "$time" -J "$name" \
                   --wrap='sleep infinity') || return 1
    [ -z "$jobid" ] && { echo "submission failed"; return 1; }
    echo "Submitted job $jobid ($name). Waiting for node assignment..."
    local node="" tries=0
    while [ "$tries" -lt 120 ]; do
        node=$(squeue -h -j "$jobid" -o '%N' 2>/dev/null)
        case "$node" in
            ""|"(null)"|n/a) ;;
            *) break ;;
        esac
        sleep 2
        tries=$((tries + 1))
    done
    if [ -z "$node" ] || [ "$node" = "(null)" ]; then
        echo "Timed out waiting for allocation. Check 'squeue --me'; scancel $jobid to drop."
        return 1
    fi
    echo "Allocation ready on: $node  (job $jobid, ${time} wall-time)"
    echo "In VS Code: Cmd/Ctrl-Shift-P → 'Remote-SSH: Connect to Host' → $node"
    echo "Release with: vscode-ssh-release $name   (or: scancel $jobid)"
}

# vscode-ssh-release: scancel vscode-ssh allocations. No arg cancels every
# 'vscode-ssh'-named job you own; pass a different job name to cancel that.
vscode-ssh-release() {
    command -v scancel >/dev/null 2>&1 || { echo "scancel not found"; return 1; }
    local name="${1:-vscode-ssh}"
    local ids
    ids=$(squeue -h -u "$USER" -n "$name" -o '%i' 2>/dev/null)
    if [ -z "$ids" ]; then
        echo "no jobs named '$name' for $USER"
        return 0
    fi
    echo "cancelling: $ids"
    # shellcheck disable=SC2086
    scancel $ids
}

# vscode-doctor: one-shot diagnostic for "VS Code is stuck / slow on this
# host". Prints where you are, what allocations exist, where the cpptools
# cache lives, and tails the latest cpptools log if cpptools has spoken.
# Read-only — never deletes anything.
vscode-doctor() {
    local h
    h="$(hostname -s 2>/dev/null || hostname)"
    echo "host:       $h"
    case "$h" in
        notchpeak[12]|granite[12]|kingspeak[12]|lonepeak[12]|ash[12])
            echo "  ⚠ this is a CHPC login node — Arbiter caps you at 4 cores / 8 GB."
            echo "    For IntelliSense, connect via 'Remote-SSH: notchpeak-compute'."
            ;;
    esac
    if command -v squeue >/dev/null 2>&1; then
        echo
        echo "vscode-* allocations:"
        local jobs
        jobs="$(squeue -h -u "$USER" -o '%i %T %N %j %L' 2>/dev/null \
                | awk '$4 ~ /^vscode-/ {print}')"
        if [ -n "$jobs" ]; then
            printf '  JOBID    STATE    NODE      NAME           TIME-LEFT\n'
            printf '  %s\n' "$jobs"
        else
            echo "  (none)"
        fi
    fi
    local machine="$HOME/.vscode-server/data/Machine/settings.json"
    if [ -f "$machine" ]; then
        local cache
        cache="$(grep -oE '"C_Cpp.intelliSenseCachePath"[^,}]*' "$machine" \
                 | sed -E 's/.*"([^"]*)"$/\1/')"
        if [ -n "$cache" ]; then
            echo
            printf "cpptools cache: %s" "$cache"
            if [ -d "$cache" ]; then
                printf " (%s)\n" "$(du -sh "$cache" 2>/dev/null | awk '{print $1}')"
            else
                printf " (not created yet)\n"
            fi
        fi
        if grep -q '"C_Cpp.intelliSenseEngine"[[:space:]]*:[[:space:]]*"disabled"' "$machine"; then
            echo "  ℹ IntelliSense is disabled by Machine settings (login-node guard)."
        fi
    fi
    local logdir="$HOME/.vscode-server/data/logs"
    if [ -d "$logdir" ]; then
        local latest
        latest="$(ls -1t "$logdir" 2>/dev/null | head -1)"
        if [ -n "$latest" ]; then
            echo
            echo "latest log session: $logdir/$latest"
            local cpplog
            cpplog="$(ls -1t "$logdir/$latest"/exthost*/output_logging_*/[0-9]*-C_C++.log 2>/dev/null | head -1)"
            if [ -n "$cpplog" ] && [ -s "$cpplog" ]; then
                echo "cpptools log tail ($cpplog):"
                tail -n 20 "$cpplog" | sed 's/^/  /'
            fi
        fi
    fi
}

# vscode-cache-clear: wipe the cpptools IntelliSense index (the 'ipch'
# directory under intelliSenseCachePath). Use when IntelliSense returns
# stale results or the parser appears wedged. Prompts before deleting.
vscode-cache-clear() {
    local machine="$HOME/.vscode-server/data/Machine/settings.json"
    local cache=""
    if [ -f "$machine" ]; then
        cache="$(grep -oE '"C_Cpp.intelliSenseCachePath"[^,}]*' "$machine" \
                 | sed -E 's/.*"([^"]*)"$/\1/')"
    fi
    [ -z "$cache" ] && cache="$HOME/.cache/vscode-cpptools"
    if [ ! -d "$cache" ]; then
        echo "cache not present: $cache"
        return 0
    fi
    local size
    size="$(du -sh "$cache" 2>/dev/null | awk '{print $1}')"
    printf 'Delete cpptools cache %s (%s)? [y/N] ' "$cache" "$size"
    local answer; read -r answer
    case "$answer" in
        [Yy]*) rm -rf "$cache" && echo "cleared." ;;
        *)     echo "kept." ;;
    esac
}

# Pre-download vscode-server for a specific VS Code commit so Remote-SSH
# first-connect is fast (or works on a node without internet). Get the commit
# from your local VS Code: Help → About → "Commit: <hash>". Idempotent.
prefetch-vscode-server() {
    local commit="${1:?usage: prefetch-vscode-server <commit-hash>}"
    local arch
    case "$(uname -m)" in
        x86_64)  arch=x64 ;;
        aarch64) arch=arm64 ;;
        *) echo "unsupported arch"; return 1 ;;
    esac
    local dst="$HOME/.vscode-server/bin/$commit"
    [ -x "$dst/bin/code-server" ] && { echo "already staged: $dst"; return 0; }
    mkdir -p "$dst"
    local url="https://update.code.visualstudio.com/commit:$commit/server-linux-$arch/stable"
    echo "fetching $url"
    if ! curl -fL "$url" | tar xz -C "$dst" --strip-components=1; then
        echo "download failed"
        rm -rf "$dst"
        return 1
    fi
    echo "staged at $dst"
}

# Manual theme override. `theme auto` re-runs detect-theme (clears the cached
# SERVER_CONFIGS_THEME first, otherwise the early-return in
# _server_configs_detect_theme would no-op). Inside tmux, propagate to the
# global env so new panes inherit and re-source the theme block to repaint
# existing panes. Running nvim/vim instances cache &background at startup and
# need `:set background=light|dark` to flip via the OptionSet autocmd.
theme() {
    case "${1:-auto}" in
        light|dark)
            export SERVER_CONFIGS_THEME="$1"
            ;;
        auto)
            # Inside tmux, auto-detect needs an in-session probe — tmux 3.6+
            # exposes #{client_theme}; older tmux has neither that nor
            # allow-passthrough'd OSC 11. Without a probe, detect-theme falls
            # through to its dark default and would overwrite a possibly-correct
            # cached value, so refuse on legacy tmux and tell the user.
            if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
                case "$(tmux display -p '#{client_theme}' 2>/dev/null)" in
                    light|dark) ;;
                    *)
                        printf 'theme: auto-detect inside tmux %s is not supported (need tmux 3.6+ #{client_theme}). Open a fresh outside-tmux terminal, or use `theme light|dark`.\n' \
                            "$(tmux -V 2>/dev/null | awk '{print $2}')" >&2
                        return 1
                        ;;
                esac
            fi
            unset SERVER_CONFIGS_THEME
            # Bust tmux's global-env cache so detect-theme step 2a falls
            # through to a real #{client_theme} re-probe instead of
            # returning the value cached by an earlier run.
            if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
                tmux set-environment -g -u SERVER_CONFIGS_THEME 2>/dev/null || true
            fi
            if command -v _server_configs_detect_theme >/dev/null 2>&1; then
                _server_configs_detect_theme force
            fi
            ;;
        -h|--help|help)
            printf 'usage: theme [light|dark|auto]\n' >&2
            return 0
            ;;
        *)
            printf 'theme: unknown argument %s (expected light|dark|auto)\n' "$1" >&2
            return 2
            ;;
    esac
    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        tmux set-environment -g SERVER_CONFIGS_THEME "${SERVER_CONFIGS_THEME:-dark}"
        [ -f "$HOME/.tmux-theme.conf" ] && tmux source-file "$HOME/.tmux-theme.conf" 2>/dev/null
    fi
    printf 'theme: SERVER_CONFIGS_THEME=%s%s\n' "${SERVER_CONFIGS_THEME:-unset}" \
        "${TMUX:+ (tmux repainted; running nvim/vim: :set background=...)}" >&2
}

# Modern tool replacements (guarded)
# bat as cat is safe — same basic interface. fd/rg are used directly (no alias)
# since aliasing grep/find breaks scripts that rely on GNU flag syntax.
