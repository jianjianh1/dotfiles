# shellcheck shell=bash

# Only run in interactive shells
[[ $- == *i* ]] || return

# PATH
export PATH="$HOME/.local/bin:$PATH"

# Cache `tool init` evals so NFS-homed shells (CHPC) don't pay the
# 50-150ms eval cost per shell. setup.sh wipes the cache dir on install
# so version bumps always regenerate.
_server_configs_load_cached_init() {
    local name="$1" cmd="$2"
    local cache_dir="$HOME/.cache/server-configs"
    # Per-shell cache (zoxide init bash != zoxide init zsh).
    local _shell="${ZSH_VERSION:+zsh}${BASH_VERSION:+bash}"
    local cache_file="$cache_dir/${name}.${_shell:-sh}"
    local header_prefix='# server-configs cached '
    local first_word bin first_line="" init_output

    first_word="${cmd%% *}"
    bin="$(command -v "$first_word" 2>/dev/null)" || return 1

    if [ -f "$cache_file" ] && [ "$cache_file" -nt "$bin" ]; then
        IFS= read -r first_line < "$cache_file" 2>/dev/null || true
    fi
    case "$first_line" in
        "${header_prefix}"*)
            source "$cache_file"
            return
            ;;
    esac

    if ! command mkdir -p "$cache_dir" 2>/dev/null || [ ! -w "$cache_dir" ]; then
        if [ -z "${_SERVER_CONFIGS_CACHE_WARNED:-}" ]; then
            _SERVER_CONFIGS_CACHE_WARNED=1
            printf '[server-configs] cache %s not writable; falling back to inline init\n' \
                "$cache_dir" >&2
        fi
        init_output="$(eval "$cmd")" && eval "$init_output"
        return
    fi
    if {
        printf '%s%s\n' "$header_prefix" "${EPOCHSECONDS:-0}"
        eval "$cmd"
    } > "$cache_file.tmp" 2>/dev/null; then
        command mv -f "$cache_file.tmp" "$cache_file"
        source "$cache_file"
    else
        command rm -f "$cache_file.tmp"
        init_output="$(eval "$cmd")" && eval "$init_output"
    fi
}

# History — zsh equivalents of the bashrc history settings.
export HISTSIZE=50000
export SAVEHIST=100000
export HISTFILE="${HISTFILE:-$HOME/.zsh_history}"
setopt APPEND_HISTORY        # append rather than overwrite
setopt INC_APPEND_HISTORY    # write each command as it runs
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS  # erasedups equivalent
setopt HIST_IGNORE_SPACE     # ignoreboth: ignorespace half
setopt HIST_REDUCE_BLANKS
setopt EXTENDED_HISTORY      # timestamps (like HISTTIMEFORMAT)

# Shell options
setopt AUTO_CD               # type a directory name to cd into it
setopt CORRECT               # autocorrect command typos (≈ cdspell + more)
setopt EXTENDED_GLOB         # globstar-equivalent ** is native; this adds the rest
unsetopt BEEP

# Terminal theme detection — exports SERVER_CONFIGS_THEME=light|dark.
# Honoured by vimrc, nvim, tmux.conf, bat, starship, delta, and the
# fallback PROMPT below.
_server_configs_detect_theme() {
    case "${SERVER_CONFIGS_THEME:-}" in
        light|dark) return 0 ;;
    esac

    local r g b lum resp

    if [ -z "${TMUX:-}" ] && [ -t 0 ] && [ -t 1 ] && [ -r /dev/tty ] && [ -w /dev/tty ]; then
        printf '\e]11;?\e\\' > /dev/tty 2>/dev/null
        IFS= read -rs -t 0.1 -d $'\a' resp < /dev/tty 2>/dev/null || resp=""
        # zsh exposes regex captures via the `match` array (with KSH_ARRAYS off,
        # which is the default).
        if [[ "$resp" =~ 'rgb:([0-9a-fA-F]+)/([0-9a-fA-F]+)/([0-9a-fA-F]+)' ]]; then
            local rh="${match[1]}" gh="${match[2]}" bh="${match[3]}"
            rh="${rh:0:2}"; gh="${gh:0:2}"; bh="${bh:0:2}"
            while [ ${#rh} -lt 2 ]; do rh="${rh}0"; done
            while [ ${#gh} -lt 2 ]; do gh="${gh}0"; done
            while [ ${#bh} -lt 2 ]; do bh="${bh}0"; done
            r=$((16#$rh)); g=$((16#$gh)); b=$((16#$bh))
            lum=$(( (299*r + 587*g + 114*b) / 1000 ))
            if [ "$lum" -gt 128 ]; then
                export SERVER_CONFIGS_THEME=light
            else
                export SERVER_CONFIGS_THEME=dark
            fi
            return 0
        fi
    fi

    if [ -n "${COLORFGBG:-}" ]; then
        local cfg_bg="${COLORFGBG##*;}"
        case "$cfg_bg" in
            0|1|2|3|4|5|6|8) export SERVER_CONFIGS_THEME=dark; return 0 ;;
            7|9|10|11|12|13|14|15) export SERVER_CONFIGS_THEME=light; return 0 ;;
        esac
    fi

    # No reliable probe succeeded. Default to dark — the common terminal
    # preference, including for users running a dark Terminal.app profile
    # on a light-mode Mac (AppleInterfaceStyle would mis-classify those).
    # Override with `export SERVER_CONFIGS_THEME=light` for light terminals.
    export SERVER_CONFIGS_THEME=dark
}
_server_configs_detect_theme

# Colored output
export CLICOLOR=1
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# Less — case-insensitive search, raw colors, no bell
export LESS='-iRQ'

# Locale
set_preferred_utf8_locale() {
    local locale_name

    for locale_name in C.UTF-8 en_US.UTF-8 en_US.utf8; do
        if LANG="$locale_name" LC_ALL="" locale charmap >/dev/null 2>&1; then
            export LANG="$locale_name"
            return 0
        fi
    done

    return 1
}

set_preferred_utf8_locale || true

# make less more friendly for non-text input files
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# fzf
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git'
fi

# bat — pick a light-readable theme when the terminal is light.
if [ "${SERVER_CONFIGS_THEME:-dark}" = "light" ]; then
    export BAT_THEME="GitHub"
else
    export BAT_THEME="TwoDark"
fi

# delta — gitconfig pins `dark = true`; override at runtime when light so
# diffs invert correctly.
if [ "${SERVER_CONFIGS_THEME:-dark}" = "light" ]; then
    export GIT_CONFIG_PARAMETERS="'delta.dark=false' 'delta.light=true'"
fi

# dircolors — load the light palette when the terminal is light.
if command -v dircolors &>/dev/null; then
    if [ "${SERVER_CONFIGS_THEME:-dark}" = "light" ] && [ -f ~/.dircolors.light ]; then
        eval "$(dircolors -b ~/.dircolors.light)"
    elif [ -f ~/.dircolors ]; then
        eval "$(dircolors -b ~/.dircolors)"
    fi
fi

# Prompt: use Starship if available, else fall back to a zsh-native PROMPT.
if command -v starship &>/dev/null; then
    if [ "${SERVER_CONFIGS_THEME:-dark}" = "light" ] && [ -f ~/.config/starship-light.toml ]; then
        export STARSHIP_CONFIG="$HOME/.config/starship-light.toml"
    fi
    eval "$(starship init zsh)"
else
    setopt PROMPT_SUBST
    __git_branch() {
        local b
        b="$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)"
        [ -n "$b" ] && printf " (%s)" "$b"
    }
    if [ "${SERVER_CONFIGS_THEME:-dark}" = "light" ]; then
        PROMPT='%F{blue}%n%f:%F{red}%~%f%F{yellow}$(__git_branch)%f%# '
    else
        PROMPT='%B%F{green}%n%f%b:%B%F{blue}%~%f%b%F{yellow}$(__git_branch)%f%# '
    fi
    case "$TERM" in
        xterm*|rxvt*) PROMPT=$'%{\e]0;%n: %~\a%}'"$PROMPT" ;;
    esac
fi

# Current directory reporting for terminal integrations — zsh precmd hook
# replaces bash's PROMPT_COMMAND.
__report_current_dir() {
    printf '\e]7;file://%s%s\a' "$HOST" "$PWD"
    if [ -n "$TMUX" ]; then
        printf '\ePtmux;\e\e]1337;CurrentDir=%s\a\e\\' "$PWD"
    else
        printf '\e]1337;CurrentDir=%s\a' "$PWD"
    fi
}
autoload -Uz add-zsh-hook 2>/dev/null \
    && add-zsh-hook precmd __report_current_dir

# Atuin: SQLite-backed shell history with context (replaces Ctrl-R).
# Atuin's zsh init wraps zle widgets — keep it after any other widget setup.
_server_configs_load_cached_init atuin "atuin init zsh --disable-up-arrow"

if [ -f ~/.server-configs-generated/bashrc_compat ]; then
    source ~/.server-configs-generated/bashrc_compat
fi

# Default editor (prefer nvim if available; set after compat for module-loaded nvim)
if command -v nvim &>/dev/null; then
    export EDITOR=nvim
    export VISUAL=nvim
else
    export EDITOR=vim
    export VISUAL=vim
fi
