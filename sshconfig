# Optional per-host compute-routing aliases (e.g. notchpeak-compute).
# Generated by setup.sh; missing files are silently ignored by ssh.
Include ~/.server-configs-generated/sshconfig.compute

# Shared connection multiplexing — reuse existing SSH connections
Host *
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

    # Keep connections alive
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Speed up connections
    AddKeysToAgent yes
    IdentitiesOnly yes
